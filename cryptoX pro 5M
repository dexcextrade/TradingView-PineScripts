 //@version=5
strategy("cryptox meme pro",
     overlay=true,
     pyramiding=0,
     initial_capital=10000,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100)

// =====================================================
// INPUTS
// =====================================================

fastEMA = input.int(7, "Fast EMA")
slowEMA = input.int(21, "Slow EMA")

breakoutLen = input.int(3, "Breakout Length")

atrLen = input.int(14, "ATR Length")

useVolume = input.bool(true, "Use Volume Filter")
volLen = input.int(20, "Volume SMA")
volMult = input.float(1.3, "Volume Multiplier")

takeProfit = input.float(10.0, "Take Profit %")
stopLoss = input.float(3.0, "Stop Loss %")

useTrailing = input.bool(true, "Use Trailing")
trailATR = input.float(1.5, "Trail ATR")

// =====================================================
// INDICATORS
// =====================================================

emaFast = ta.ema(close, fastEMA)
emaSlow = ta.ema(close, slowEMA)

atr = ta.atr(atrLen)

avgVol = ta.sma(volume, volLen)

// =====================================================
// FILTERS
// =====================================================

bullTrend = emaFast > emaSlow
bearTrend = emaFast < emaSlow

volOK =
     not useVolume
     ? true
     : volume > avgVol * volMult

// =====================================================
// BREAKOUT LOGIC
// =====================================================

highestHigh = ta.highest(high, breakoutLen)[1]
lowestLow = ta.lowest(low, breakoutLen)[1]

longBreak =
     close > highestHigh and close > open

shortBreak =
     close < lowestLow and close < open

// =====================================================
// FINAL SIGNALS
// =====================================================

longSignal =
     bullTrend and
     longBreak and
     volOK

shortSignal =
     bearTrend and
     shortBreak and
     volOK

// =====================================================
// ENTRIES
// =====================================================

if longSignal
    strategy.entry("LONG", strategy.long)

if shortSignal
    strategy.entry("SHORT", strategy.short)

// =====================================================
// TP / SL
// =====================================================

longTP = strategy.position_avg_price * (1 + takeProfit / 100)
longSL = strategy.position_avg_price * (1 - stopLoss / 100)

shortTP = strategy.position_avg_price * (1 - takeProfit / 100)
shortSL = strategy.position_avg_price * (1 + stopLoss / 100)

// =====================================================
// TRAILING
// =====================================================

trailOffset = atr * trailATR

// =====================================================
// EXITS
// =====================================================

if useTrailing
    strategy.exit("LONG EXIT", "LONG", limit=longTP, stop=longSL, trail_offset=trailOffset)
    strategy.exit("SHORT EXIT", "SHORT", limit=shortTP, stop=shortSL, trail_offset=trailOffset)
else
    strategy.exit("LONG EXIT", "LONG", limit=longTP, stop=longSL)
    strategy.exit("SHORT EXIT", "SHORT", limit=shortTP, stop=shortSL)

// =====================================================
// VISUALS
// =====================================================

plot(emaFast, color=color.lime, linewidth=2)
plot(emaSlow, color=color.orange, linewidth=2)

plotshape(longSignal, location=location.belowbar, color=color.lime, style=shape.labelup, text="LONG")
plotshape(shortSignal, location=location.abovebar, color=color.red, style=shape.labeldown, text="SHORT")

// =====================================================
// ALERTS
// =====================================================

alertcondition(longSignal, "LONG", "LONG ENTRY")
alertcondition(shortSignal, "SHORT", "SHORT ENTRY")
